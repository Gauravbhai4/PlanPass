# ============================================================
# Azure OpenAI Configuration
# ============================================================
# 1. Get these values from Azure Portal -> Your Azure OpenAI resource -> Keys and Endpoint
# 2. Copy this file to .env in the same folder
# 3. Fill in real values below
# ============================================================

# Your Azure OpenAI endpoint URL.
# Format: https://YOUR_RESOURCE_NAME.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/

# Your Azure OpenAI API key (KEY 1 or KEY 2 from the portal)
AZURE_OPENAI_API_KEY=your-api-key-here

# The name of the model DEPLOYMENT you created in Azure OpenAI Studio.
# Note: this is NOT the model name like "gpt-4o" - it's the DEPLOYMENT NAME
# you chose when deploying the model. Both flows use this for text completion.
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# OPTIONAL: A separate deployment for vision (reading plan PDFs as images).
# If left blank, AZURE_OPENAI_DEPLOYMENT_NAME above is used.
# REQUIREMENTS: This deployment must be a vision-capable model:
#   - gpt-4o
#   - gpt-4o-mini
#   - gpt-4-turbo (with vision)
# If your main deployment is one of those, leave this blank.
AZURE_OPENAI_VISION_DEPLOYMENT_NAME=

# API version - use a stable one. 2024-10-21 is GA and supports JSON-mode
# AND vision. 2024-12-01-preview includes the latest features.
AZURE_OPENAI_API_VERSION=2024-10-21

# ============================================================
# App Settings (optional - defaults are fine)
# ============================================================
APP_HOST=127.0.0.1
APP_PORT=8000
